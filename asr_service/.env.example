# Qwen3-ASR OpenAI-compatible API
# Put your real key in asr_service/.env only. Do not commit real keys.
QWEN_ASR_API_KEY=your_real_key
QWEN_ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_ASR_MODEL=qwen3-asr-flash-realtime
QWEN_ASR_REALTIME_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime

# Optional
ASR_SAMPLE_RATE=16000
QWEN_ASR_TIMEOUT_SECONDS=60
QWEN_ASR_LANGUAGE=en
QWEN_ASR_ENABLE_ITN=true
QWEN_ASR_VAD_THRESHOLD=0.0
QWEN_ASR_SILENCE_DURATION_MS=400
ASR_MIN_RMS=0.003
QWEN_ASR_CONTEXT=GUI agent patient editor. Common patient IDs include P001 P002 P003 P004 P005. Common fields include phone department visitType insuranceType symptoms remark.
