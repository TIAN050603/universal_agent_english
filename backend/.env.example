LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=http://127.0.0.1:8001/v1
LLM_MODEL=gpt-5.5
LLM_REQUEST_TIMEOUT_SECONDS=75
LLM_STATUS_TEST_TIMEOUT_SECONDS=10

# Upstream settings for scripts/llm_openai_proxy.py in the reference deployment.
LLM_PROXY_API_KEY=
LLM_PROXY_BASE_URL=https://your-openai-compatible-endpoint.example/v1
LLM_PROXY_MODEL=gpt-5.5

# Remote Diart service. Keep the proxy token identical to the named Modal secret.
DIARIZATION_INTERNAL_URL=https://YOUR-MODAL-URL.modal.run
DIARIZATION_PROXY_TOKEN=
MODAL_PROXY_TOKEN_ID=wk-REPLACE_ME
MODAL_PROXY_TOKEN_SECRET=ws-REPLACE_ME
DIARIZATION_HEALTH_TIMEOUT_SECONDS=45
DIARIZATION_WS_OPEN_TIMEOUT_SECONDS=60
