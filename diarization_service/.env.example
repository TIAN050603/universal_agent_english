# Diarization service local environment.
# Copy this file to .env and fill in real values on the server.
# Never commit real tokens.

# Required for pyannote-backed Diart models.
# Accept access conditions for:
# - https://huggingface.co/pyannote/segmentation
# - https://huggingface.co/pyannote/embedding
HF_TOKEN=
HUGGINGFACE_TOKEN=

# Optional service/runtime settings.
DIARIZATION_PROVIDER=diart_local
DIARIZATION_NUM_SPEAKERS=2
DIARIZATION_DEVICE=cuda
DIARIZATION_PRELOAD_MODEL=1
